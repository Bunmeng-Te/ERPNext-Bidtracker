      "reqd": 1
    },
    {
      "fieldname": "total_timesheet_cost",
      "label": "Total Timesheet Cost",
      "fieldtype": "Currency",
      "read_only": 1
    },
    {
      "fieldname": "total_manual_cost",
      "label": "Total Manual Cost",
      "fieldtype": "Currency",
      "read_only": 1
    },
    {
      "fieldname": "total_bid_cost",
      "label": "Total Bid Cost",
      "fieldtype": "Currency",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "estimated_profit",
      "label": "Estimated Profit",
      "fieldtype": "Currency",
      "read_only": 1
    },
    {
      "fieldname": "roi_ratio",
      "label": "ROI Ratio",
      "fieldtype": "Percent",
      "read_only": 1
    },
    {
