    },
    {
      "fieldname": "opportunity",
      "label": "Opportunity",
      "fieldtype": "Link",
      "options": "Opportunity",
      "in_list_view": 1
    },
    {
      "fieldname": "customer",
      "label": "Customer",
      "fieldtype": "Link",
      "options": "Customer"
    },
    {
      "fieldname": "pursuit_decision_date",
      "label": "Pursuit Decision Date",
      "fieldtype": "Date"
    },
    {
      "fieldname": "bid_submission_date",
      "label": "Bid Submission Date",
      "fieldtype": "Date"
    },
    {
      "fieldname": "bid_owner",
      "label": "Bid Owner",
      "fieldtype": "Link",
      "options": "User",
      "default": "__user"
    },
    {
      "fieldname": "assigned_team_members",
      "label": "Assigned Team Members",
      "fieldtype": "Data"
    },
    {
