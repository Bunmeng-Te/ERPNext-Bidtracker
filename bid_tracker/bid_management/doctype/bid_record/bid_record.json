{
  "doctype": "DocType",
  "name": "Bid Record",
  "module": "Bid Management",
  "custom": 0,
  "istable": 0,
  "editable_grid": 0,
  "engine": "InnoDB",
  "autoname": "",
  "track_changes": 1,
