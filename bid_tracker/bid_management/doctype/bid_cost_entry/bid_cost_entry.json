{
  "doctype": "DocType",
  "name": "Bid Cost Entry",
  "module": "Bid Management",
  "custom": 0,
  "istable": 0,
  "editable_grid": 0,
  "engine": "InnoDB",
  "autoname": "naming_series:",
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "naming_series",
      "label": "Series",
      "fieldtype": "Select",
      "options": "BCE-.YYYY.-.#####",
      "default": "BCE-.YYYY.-.#####",
      "reqd": 1
    },
    {
      "fieldname": "bid_record",
      "label": "Bid Record",
      "fieldtype": "Link",
      "options": "Bid Record",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "cost_type",
      "label": "Cost Type",
      "fieldtype": "Select",
      "options": "Travel\nPrinting\nSubcontractor Quote\nMaterials\nAdmin\nOther",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "description",
      "label": "Description",
      "fieldtype": "Data"
    },
    {
      "fieldname": "amount",
      "label": "Amount",
      "fieldtype": "Currency",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "cost_date",
      "label": "Cost Date",
      "fieldtype": "Date",
      "default": "Today"
    },
    {
      "fieldname": "added_by",
      "label": "Added By",
      "fieldtype": "Link",
      "options": "User",
      "default": "__user"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Accounts Manager",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Sales Manager",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Employee",
      "read": 1
    }
  ]
}
